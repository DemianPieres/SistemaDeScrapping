# Configuración de la aplicación
APP_NAME=LeadScraper Argentina
APP_ENV=development
DEBUG=true

# Base de datos
# Por defecto SQLite (no requiere instalación):
DATABASE_URL=sqlite:///./leadscraper.db
# Para PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://leadscraper:leadscraper@localhost:5432/leadscraper

# CORS (lista separada por comas)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Scraping
SCRAPER_HEADLESS=true
SCRAPER_DEFAULT_RADIUS_KM=2
SCRAPER_MAX_RESULTS_PER_QUERY=40
SCRAPER_REQUEST_DELAY_SECONDS=1.5
SCRAPER_PAGE_TIMEOUT_SECONDS=25
# Si Selenium no encuentra Chrome solo, completá las rutas:
CHROME_BINARY_PATH=
CHROMEDRIVER_PATH=

# Análisis web
WEBSITE_ANALYZER_TIMEOUT=10
